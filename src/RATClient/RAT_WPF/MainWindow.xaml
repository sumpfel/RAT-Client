<Window x:Class="RAT_WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RAT_WPF" 
        xmlns:views="clr-namespace:RAT_WPF.Views"
        xmlns:vms="clr-namespace:RAT_WPF.ViewModels"
        mc:Ignorable="d"
        Title="RAT" Height="720" Width="1180" MinHeight="500" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Icon="{StaticResource AppLogo}"
        Background="{DynamicResource Brush.Background}">
    <!--KI start (Claude Opus 4.8, prompt 2): logo as window icon + themed background-->
    <Grid Margin="10 0 0 0">
        <Grid.Resources>
            <DataTemplate DataType="{x:Type vms:LoginViewModel}">
                <views:LoginView/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vms:TopologyViewModel}">
                <views:TopologyView/>
            </DataTemplate>
        </Grid.Resources>

        <!--KI start (Claude Opus 4.8, prompt 20): app-wide zoom via a LayoutTransform on the shell content.
             ZoomManager raises ZoomChanged; the code-behind updates this ScaleTransform. -->
        <ContentControl Content="{Binding CurrentViewModel}">
            <ContentControl.LayoutTransform>
                <ScaleTransform x:Name="ZoomTransform" ScaleX="1" ScaleY="1"/>
            </ContentControl.LayoutTransform>
        </ContentControl>
        <!--KI end-->

    </Grid>
    <!--KI end-->
</Window>
