<UserControl x:Class="RAT_WPF.Views.NetworkObjectView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:RAT_WPF.Views"
             mc:Ignorable="d"
             d:DesignHeight="90" d:DesignWidth="90" x:Name="grid">
    <!--KI start (Claude Opus 4.8, prompt 2): canvas node with device icon-->
    <Grid Width="90" Height="96" MouseMove="Grid_MouseMove">
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{DynamicResource Brush.Surface}" CornerRadius="8" Padding="4">
            <Image Source="{Binding Type, Converter={StaticResource IconKeyConverter}}"/>
        </Border>
        <TextBlock Grid.Row="1" Text="{Binding Type}" HorizontalAlignment="Center"
                   Foreground="{DynamicResource Brush.Text}" FontSize="11"/>
        <Button Grid.Row="2" Content="Settings" Command="{Binding NetworkObjectOpenSettings}"
                Style="{StaticResource SubtleButton}" Padding="6,2" FontSize="11"/>
    </Grid>
    <!--KI end-->
</UserControl>
