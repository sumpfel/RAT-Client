<UserControl x:Class="RAT_WPF.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RAT_WPF.Views"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             Background="{DynamicResource Brush.Background}">
    <!--KI start (Claude Opus 4.8, prompt 2): logo header + themed login-->
    <Grid MaxWidth="800" Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Image Source="{StaticResource AppLogo}" Width="48" Height="48" Margin="0,0,12,0"/>
            <TextBlock Text="Login" Style="{StaticResource Header}" VerticalAlignment="Center"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0 25 0 0">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <TextBlock 
                Grid.Row="0" 
                Text="Username" 
                Style="{StaticResource Header2}"/>

            <TextBox 
                Grid.Row="1" 
                Margin="0 10 0 0" 
                Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                Background="{Binding TextBoxUsernameColor}"/>

        </Grid>

        <Grid Grid.Row="2" Margin="0 25 0 0">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <TextBlock 
                Grid.Row="0" 
                Text="Password" 
                Style="{StaticResource Header2}"/>
            
            <PasswordBox
                Grid.Row="1"
                Margin="0 10 0 0"
                x:Name="PasswordBoxLogin"
                Background="{Binding TextBoxPasswordColor}"
                PasswordChanged="PasswordBoxLogin_PasswordChanged"
                />
        </Grid>

        <Grid Grid.Row="3" Margin="0 25 0 0">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" MinWidth="100"/>
                <ColumnDefinition Width="auto" MinWidth="75"/>
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Row="0"
                Grid.Column="0"
                Text="Server"
                Style="{StaticResource Header2}"/>

            <TextBlock 
                Grid.Row="1" 
                Grid.Column="0" 
                Text="IPv4"/>

            <TextBlock 
                Grid.Row="1" 
                Grid.Column="1" 
                Text="Port"
                Margin="10 0 0 0"/>
            
            <TextBox 
                Grid.Row="2" 
                Grid.Column="0"
                Text="{Binding ServerIp, UpdateSourceTrigger=PropertyChanged}"
                Background="{Binding TextBoxServerIpColor}"/>

            <TextBox 
                Grid.Row="2" 
                Grid.Column="1"
                Margin="10 0 0 0"
                Text="{Binding ServerPort, UpdateSourceTrigger=PropertyChanged}"
                Background="{Binding TextBoxServerPortColor}"/>
        </Grid>

        <StackPanel
            Orientation="Horizontal"
            Grid.Row="4"
            Margin="0 50 0 0">
            <Button
                Content="Confirm" Command="{Binding ConfirmCommand}" Style="{StaticResource ModernButton}"/>

            <!--KI start (Claude Opus 4.8, prompt 15): rat login-status (happy rat on success, sad rat on failure)-->
            <Image Source="{Binding StatusIcon}" Visibility="{Binding StatusVisible}"
                   Width="32" Height="32" Margin="16,0,8,0" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" TextWrapping="Wrap"
                       Foreground="{DynamicResource Brush.Text}"/>
            <!--KI end-->
        </StackPanel>

    </Grid>
    <!--KI end-->
</UserControl>
