<UserControl x:Class="RAT_WPF.Views.TopologyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:views="clr-namespace:RAT_WPF.Views"
             xmlns:viewmodels="clr-namespace:RAT_WPF.ViewModels"
             xmlns:converters="clr-namespace:RAT_WPF.Views.Converters"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             Background="{DynamicResource Brush.Background}">
    <!--KI start (Claude Opus 4.8, prompt 2/10): brown-themed topbar with logo + Settings + enum-bound tools-->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>

        <!--Topbar-->
        <!--
        // ComparisonConverter for enum-bound radio tools - Source: https://stackoverflow.com/a/2908885
        // Posted by Scott, modified by community. Retrieved 2026-06-11, License - CC BY-SA 4.0
        -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="{DynamicResource Brush.Surface}" Padding="8,6">
            <Border.Resources>
                <converters:ComparisonConverter x:Key="ComparisonConverter"/>
            </Border.Resources>
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <Image Source="{StaticResource AppLogo}" Width="28" Height="28" Margin="0,0,8,0"/>
                    <TextBlock Text="RAT" Style="{StaticResource Header2}" VerticalAlignment="Center"/>
                </StackPanel>
                <!--KI start (Claude Opus 4.8, prompt 15): log out -> back to the login screen (rat door icon)-->
                <Button DockPanel.Dock="Right" Style="{StaticResource SubtleButton}"
                        HorizontalAlignment="Right" Margin="0,0,8,0" Command="{Binding LogoutCommand}">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="{StaticResource Icon.Logout}" Width="18" Height="18" Margin="0,0,6,0"/>
                        <TextBlock Text="Logout" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <!--KI end-->
                <!--KI start (Claude Opus 4.8, prompt 14): admin-only Users button (visibility set in code-behind)-->
                <Button DockPanel.Dock="Right" x:Name="UsersButton" Content="👤 Users"
                        Style="{StaticResource SubtleButton}" Visibility="Collapsed"
                        HorizontalAlignment="Right" Margin="0,0,8,0" Click="UsersButton_Click"/>
                <!--KI end-->
                <Button DockPanel.Dock="Right" Content="⚙ Settings" Style="{StaticResource SubtleButton}"
                        HorizontalAlignment="Right" Click="SettingsButton_Click"/>
                <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                    <!--Tools (Cursor/Connection are enum-bound to ToolEnum) -->
                    <RadioButton Content="🖱 Cursor" Style="{StaticResource RadioButtonTool}"
                                 IsChecked="{Binding Path=ToolEnum, Converter={StaticResource ComparisonConverter}, ConverterParameter={x:Static viewmodels:EnumTool.Cursor}}" />
                    <RadioButton Content="🔌 Connection" Style="{StaticResource RadioButtonTool}"
                                 IsChecked="{Binding Path=ToolEnum, Converter={StaticResource ComparisonConverter}, ConverterParameter={x:Static viewmodels:EnumTool.Connector}}" />
                    <RadioButton Content="🗑 Delete" Style="{StaticResource RadioButtonTool}"
                                 IsChecked="{Binding Path=ToolEnum, Converter={StaticResource ComparisonConverter}, ConverterParameter={x:Static viewmodels:EnumTool.Delete}}" />
                </StackPanel>
            </DockPanel>
        </Border>


        <!--Sidebar-->
        <views:NetworkObjectListingView
            Grid.Row="1"
            Grid.Column="0"
            DataContext="{Binding defaultItems}"
            />
        <!--Canvas-->
        <!-- Per View - Over Complex, not needed
        <views:CanvasView
            Grid.Row="1"
            Grid.Column="1"
            NetworkObjectDropCommand="{Binding}"
            />
        -->
        <!--Help from AI-->
        <Grid Grid.Row="1" Grid.Column="1" ClipToBounds="True">
            <ItemsControl ItemsSource="{Binding NetworkConnectionViewModels}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas Background="{DynamicResource Brush.Canvas}"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Line X1="{Binding xSource}" Y1="{Binding ySource}" X2="{Binding xTarget}" Y2="{Binding yTarget}" StrokeThickness="2" Stroke="Black"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            
            <ItemsControl ItemsSource="{Binding NetworkObjects}">

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <views:NetworkObjectView
                CurrentTool="{Binding DataContext.ToolEnum, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CommandLeftClickWithConnectionTool="{Binding DataContext.NetworkObjectAddConnectionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                CommandLeftClickWithDeleteTool="{Binding DataContext.NetworkObjectDeleteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas
                AllowDrop="True"
                Drop="NetworkObject_Drop"
                DragOver="NetworkObject_DragOver"
                Background="Transparent"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding X, Mode=TwoWay}"/>
                        <Setter Property="Canvas.Top" Value="{Binding Y, Mode=TwoWay}"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
            </ItemsControl>
        </Grid>
        <!--No more Help from AI-->
    </Grid>
    <!--KI end-->
</UserControl>
