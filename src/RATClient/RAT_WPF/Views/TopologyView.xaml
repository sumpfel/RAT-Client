<UserControl x:Class="RAT_WPF.Views.TopologyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:views="clr-namespace:RAT_WPF.Views"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             Background="{DynamicResource Brush.Background}">
    <!--KI start (Claude Opus 4.8, prompt 2): brown-themed topbar with logo + Settings button-->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>

        <!--Topbar-->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="{DynamicResource Brush.Surface}" Padding="8,6">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <Image Source="{StaticResource AppLogo}" Width="28" Height="28" Margin="0,0,8,0"/>
                    <TextBlock Text="RAT" Style="{StaticResource Header2}" VerticalAlignment="Center"/>
                </StackPanel>
                <Button DockPanel.Dock="Right" Content="⚙ Settings" Style="{StaticResource SubtleButton}"
                        HorizontalAlignment="Right" Click="SettingsButton_Click"/>
                <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                    <!--Tools-->
                    <RadioButton Content="Cursor" Style="{StaticResource RadioButtonTool}" IsChecked="True"/>
                    <RadioButton Content="Ping" Style="{StaticResource RadioButtonTool}"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!--Sidebar-->
        <views:NetworkObjectListingView
            Grid.Row="1"
            Grid.Column="0"
            DataContext="{Binding defaultItems}"
            />
        <!--Canvas-->
        <!-- Per View - Over Complex, not needed
        <views:CanvasView
            Grid.Row="1"
            Grid.Column="1"
            NetworkObjectDropCommand="{Binding}"
            />
        -->
        <ItemsControl ItemsSource="{Binding NetworkObjects}" Grid.Row="1" Grid.Column="1">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <views:NetworkObjectView/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
            <!--Help from AI-->
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas 
                        AllowDrop="True" 
                        Drop="NetworkObject_Drop" 
                        DragOver="NetworkObject_DragOver" 
                        Background="WhiteSmoke"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="Canvas.Left" Value="{Binding X, Mode=TwoWay}"/>
                    <Setter Property="Canvas.Top" Value="{Binding Y, Mode=TwoWay}"/>
                </Style>
            </ItemsControl.ItemContainerStyle>
            <!--No more Help from AI-->
        </ItemsControl>
    </Grid>
    <!--KI end-->
</UserControl>
