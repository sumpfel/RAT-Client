<UserControl x:Class="RAT_WPF.Views.TopologyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:views="clr-namespace:RAT_WPF.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>
        <!--Topbar-->
        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal">
            <!--TODO: BurgerButton with Settings-->
            <StackPanel Orientation="Horizontal">
                <!--Tools-->
                <RadioButton Content="Cursor" Style="{StaticResource RadioButtonTool}"/>
                <RadioButton Content="Ping" Style="{StaticResource RadioButtonTool}"/>
            </StackPanel>
        </StackPanel>

        <!--Sidebar-->
        <views:NetworkObjectListingView
            Grid.Row="1"
            Grid.Column="0"
            DataContext="{Binding defaultItems}"
            />
        <!--Canvas-->
        <!-- Per View - Over Complex, not needed
        <views:CanvasView
            Grid.Row="1"
            Grid.Column="1"
            NetworkObjectDropCommand="{Binding}"
            />
        -->
        <ItemsControl ItemsSource="{Binding NetworkObjects}" Grid.Row="1" Grid.Column="1">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <views:NetworkObjectView/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
            <!--Help from AI-->
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas 
                        AllowDrop="True" 
                        Drop="NetworkObject_Drop" 
                        DragOver="NetworkObject_DragOver" 
                        Background="WhiteSmoke"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="Canvas.Left" Value="{Binding X, Mode=TwoWay}"/>
                    <Setter Property="Canvas.Top" Value="{Binding Y, Mode=TwoWay}"/>
                </Style>
            </ItemsControl.ItemContainerStyle>
            <!--No more Help from AI-->
        </ItemsControl>
    </Grid>
</UserControl>
