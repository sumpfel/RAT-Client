<Window x:Class="RAT_WPF.EnterPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RAT_WPF"
        mc:Ignorable="d"
        Title="Enter password" Width="260" MinWidth="220"
        SizeToContent="Height"
        Icon="{StaticResource AppLogo}"
        Background="{DynamicResource Brush.Background}"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">
    <!--KI start (Claude Opus 4.8, prompt 2): themed password dialog-->
    <Border Style="{StaticResource Card}" Margin="10">
        <StackPanel>
            <TextBlock Text="Enter password" Style="{StaticResource FieldLabel}"/>
            <PasswordBox x:Name="password" FontSize="14" PasswordChar="◆" Padding="6,4"
                         Background="{DynamicResource Brush.SurfaceAlt}"
                         Foreground="{DynamicResource Brush.Text}"
                         BorderBrush="{DynamicResource Brush.Border}"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                <Button Content="Cancel" Style="{StaticResource SubtleButton}" Click="Button_Click_1"/>
                <Button Content="Save" Style="{StaticResource ModernButton}" Click="Button_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
    <!--KI end-->
</Window>
