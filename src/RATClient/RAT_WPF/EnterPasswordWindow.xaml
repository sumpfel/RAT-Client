<Window x:Class="RAT_WPF.EnterPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RAT_WPF"
        mc:Ignorable="d"
        Title="EnterPasswordWindow" Height="105" Width="125">
    <StackPanel>
        <Label Content="Enter password:"></Label>
        <PasswordBox x:Name="password" FontSize="15" MinWidth="100" PasswordChar="◆" Margin="5"></PasswordBox>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="cancel" Margin="2" FontSize="15" Click="Button_Click_1"></Button>
            <Button Content="save" FontSize="15" Margin="2" Click="Button_Click"></Button>
        </StackPanel>
    </StackPanel>
</Window>
