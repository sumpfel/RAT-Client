<!--KI start (Claude Opus 4.8, prompt 2): hand-built vector RAT icons (transparent bg, brown palette).
     Stylized/cartoonish vector art. Can be overridden at runtime by dropping a matching PNG into
     Assets/Icons/<key>.png (see IconProvider) for true anime artwork later. -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         Icon: PC  (a rat sitting at / using a computer)
         ============================================================ -->
    <DrawingImage x:Key="Icon.PC">
        <DrawingImage.Drawing>
            <DrawingGroup>
                <!-- monitor body -->
                <GeometryDrawing Brush="#FF5A3A28">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="34,12,56,40" RadiusX="4" RadiusY="4"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- screen -->
                <GeometryDrawing Brush="#FFD9B58A">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="40,18,44,28" RadiusX="2" RadiusY="2"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- stand -->
                <GeometryDrawing Brush="#FF3B2418">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="56,52,12,6"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- rat body -->
                <GeometryDrawing Brush="#FF5A3A28">
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="22,70" RadiusX="16" RadiusY="13"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- rat head -->
                <GeometryDrawing Brush="#FF5A3A28">
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="36,62" RadiusX="10" RadiusY="9"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- ear -->
                <GeometryDrawing Brush="#FFC97A4A">
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="30,54" RadiusX="5" RadiusY="5"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- eye -->
                <GeometryDrawing Brush="#FF2A1A10">
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="40,61" RadiusX="1.6" RadiusY="1.6"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- tail -->
                <GeometryDrawing>
                    <GeometryDrawing.Pen><Pen Brush="#FF6B4A3A" Thickness="3"/></GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <PathGeometry Figures="M8,72 C0,64 4,82 14,80"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <!-- little paw reaching to keyboard -->
                <GeometryDrawing Brush="#FFD9B58A">
                    <GeometryDrawing.Geometry>
                        <EllipseGeometry Center="46,68" RadiusX="3" RadiusY="3"/>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingImage.Drawing>
    </DrawingImage>

