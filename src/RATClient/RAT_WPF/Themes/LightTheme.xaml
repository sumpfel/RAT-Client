<!--KI start (Claude Opus 4.8, prompt 2): Light "paper + brown" theme matching doc/markdown/style/rats.css-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- rats.css palette:
         fur-dark #3b2418  fur #5a3a28  fur-light #8a5a3c  belly #d9b58a
         ear #c97a4a  tail #6b4a3a  paper #f6efe4  paper-deep #ece2cf
         ink #2a1a10  accent #b85c2a -->

    <SolidColorBrush x:Key="Brush.Background" Color="#FFF6EFE4"/>
    <SolidColorBrush x:Key="Brush.Surface"    Color="#FFECE2CF"/>
    <SolidColorBrush x:Key="Brush.SurfaceAlt" Color="#FFE3D6BE"/>
    <SolidColorBrush x:Key="Brush.Accent"     Color="#FFB85C2A"/>
    <SolidColorBrush x:Key="Brush.AccentHover" Color="#FFC97A4A"/>
    <SolidColorBrush x:Key="Brush.OnAccent"   Color="#FFF6EFE4"/>
    <SolidColorBrush x:Key="Brush.Text"       Color="#FF2A1A10"/>
    <SolidColorBrush x:Key="Brush.TextMuted"  Color="#FF6B4A3A"/>
    <SolidColorBrush x:Key="Brush.Heading"    Color="#FF5A3A28"/>
    <SolidColorBrush x:Key="Brush.Border"     Color="#FFC9B79A"/>
    <SolidColorBrush x:Key="Brush.Danger"     Color="#FFB23A2A"/>
    <SolidColorBrush x:Key="Brush.Success"    Color="#FF5A7A3C"/>
    <SolidColorBrush x:Key="Brush.FurDark"    Color="#FF3B2418"/>
    <SolidColorBrush x:Key="Brush.Fur"        Color="#FF5A3A28"/>
    <SolidColorBrush x:Key="Brush.Ear"        Color="#FFC97A4A"/>
    <!--KI start (Claude Opus 4.8, prompt 4/5/6): canvas follows theme but is a touch distinct from the rest-->
    <SolidColorBrush x:Key="Brush.Canvas"       Color="#FFFBF6EC"/>
    <SolidColorBrush x:Key="Brush.CanvasNode"   Color="#FFF6EFE4"/>
    <SolidColorBrush x:Key="Brush.CanvasNodeText" Color="#FF2A1A10"/>
    <!--KI end-->

    <!--KI start (Claude Opus 4.8, prompt 13): SSH terminal palette — kept a warm dark console even in light mode
         (a terminal reads best dark) so it stays on-brand with the brown identity. -->
    <SolidColorBrush x:Key="Term.Background" Color="#FF241811"/>
    <SolidColorBrush x:Key="Term.InputBg"   Color="#FF2E1E14"/>
    <SolidColorBrush x:Key="Term.Header"    Color="#FF3B2418"/>
    <SolidColorBrush x:Key="Term.Text"      Color="#FFF2E8D8"/>
    <SolidColorBrush x:Key="Term.Muted"     Color="#FFC2A98F"/>
    <SolidColorBrush x:Key="Term.Prompt"    Color="#FFE8B070"/>
    <SolidColorBrush x:Key="Term.User"      Color="#FF9AcC74"/>
    <SolidColorBrush x:Key="Term.Host"      Color="#FF74BCAA"/>
    <SolidColorBrush x:Key="Term.Path"      Color="#FF7CB4E8"/>
    <SolidColorBrush x:Key="Term.Command"   Color="#FFF2E8D8"/>
    <SolidColorBrush x:Key="Term.Flag"      Color="#FFE0A86A"/>
    <SolidColorBrush x:Key="Term.String"    Color="#FFCBDE92"/>
    <SolidColorBrush x:Key="Term.Number"    Color="#FFE6BAF4"/>
    <SolidColorBrush x:Key="Term.Dir"       Color="#FF7CB4E8"/>
    <SolidColorBrush x:Key="Term.Exec"      Color="#FF9ACC74"/>
    <SolidColorBrush x:Key="Term.Archive"   Color="#FFE8B070"/>
    <SolidColorBrush x:Key="Term.Image"     Color="#FFDFA4E0"/>
    <SolidColorBrush x:Key="Term.Code"      Color="#FFEDCD62"/>
    <SolidColorBrush x:Key="Term.Error"     Color="#FFF07A7A"/>
    <SolidColorBrush x:Key="Term.Warn"      Color="#FFE8C25A"/>
    <SolidColorBrush x:Key="Term.Success"   Color="#FF98D874"/>
    <SolidColorBrush x:Key="Term.Border"    Color="#FF5A3A28"/>
    <!--KI end-->
</ResourceDictionary>
<!--KI end-->
