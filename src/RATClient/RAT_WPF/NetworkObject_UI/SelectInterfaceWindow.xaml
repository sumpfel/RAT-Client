<Window x:Class="RAT_WPF.NetworkObject_UI.SelectInterfaceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RAT_WPF.NetworkObject_UI"
        mc:Ignorable="d"
        Title="Select interface" Width="420" MinWidth="320" Height="380" MinHeight="240"
        Icon="{StaticResource AppLogo}"
        Background="{DynamicResource Brush.Background}"
        TextElement.Foreground="{DynamicResource Brush.Text}"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">
    <!--KI start (Claude Opus 4.8, prompt 9): pick an interface of a device; returns the chosen NetworkObjectInterface-->
    <Border Margin="16" Background="{DynamicResource Brush.Surface}" CornerRadius="8" Padding="18">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top" Text="Select interface" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,2"/>
            <TextBlock DockPanel.Dock="Top" x:Name="SubtitleText" Foreground="{DynamicResource Brush.TextMuted}"
                       FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>

            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                <Button Content="Cancel" Style="{StaticResource SubtleButton}" Click="Cancel_Click"/>
                <Button Content="Select" Style="{StaticResource ModernButton}" Click="Select_Click"/>
            </StackPanel>

            <ListBox x:Name="InterfaceList" Background="Transparent" BorderThickness="0"
                     MouseDoubleClick="InterfaceList_MouseDoubleClick">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource Brush.SurfaceAlt}" CornerRadius="6" Margin="0,3" Padding="10,7">
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                           Foreground="{DynamicResource Brush.Text}"/>
                                <TextBlock Foreground="{DynamicResource Brush.TextMuted}" FontSize="11"
                                           Text="{Binding IP.IPv4, TargetNullValue='no IP set'}"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Border>
    <!--KI end-->
</Window>
