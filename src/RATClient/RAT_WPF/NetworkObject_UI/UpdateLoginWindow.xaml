<Window x:Class="RAT_WPF.NetworkObject_UI.UpdateLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RAT_WPF.NetworkObject_UI"
        mc:Ignorable="d"
        Title="UpdateLoginWindow" Height="255" Width="800">
    <Grid Background="LightGray">
        <StackPanel Orientation="Vertical" Margin="2">
            <Label Content="port:"></Label>
            <TextBox x:Name="port" FontSize="15" MinWidth="100" Text="22"></TextBox>
            <Label Content="username:"></Label>
            <TextBox x:Name="username" FontSize="15" MinWidth="100" Text=""></TextBox>
            <Label Content="password/keyname:"></Label>
            <PasswordBox x:Name="password" FontSize="15" MinWidth="100" PasswordChar="◆" Password=""></PasswordBox>
            <Label Content="potocoll:"></Label>
            <TextBox x:Name="protocoll" FontSize="15" MinWidth="50" Text="ssh"></TextBox>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="cancel" Margin="2" FontSize="20" Click="Button_Click_1"></Button>
                <Button Content="save" FontSize="20" Margin="2" Click="Button_Click"></Button>
            </StackPanel>

        </StackPanel>
    </Grid>
</Window>
