<Window x:Class="RAT_WPF.NetworkObject_UI.NetworkObjectSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RAT_WPF"
        mc:Ignorable="d"
        Title="Device Settings" Height="820" Width="1040" MinHeight="540" MinWidth="720"
        WindowStartupLocation="CenterScreen"
        Icon="{StaticResource AppLogo}"
        Background="{DynamicResource Brush.Background}"
        TextElement.Foreground="{DynamicResource Brush.Text}"
        FontFamily="Segoe UI">
    <!--KI start (Claude Opus 4.8, prompt 1): full restyle + editable overview + MIB browser + access control-->
    <Window.Resources>
        <!-- Tab styling local to this window -->
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextMuted}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="bd" Background="Transparent" Padding="14,8" Margin="0,0,2,0"
                                CornerRadius="6,6,0,0">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource Brush.Surface}"/>
                                <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource Brush.SurfaceAlt}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <TabControl Background="{DynamicResource Brush.Surface}" BorderThickness="0">
            <!-- ============ OVERVIEW ============ -->
            <TabItem Header="Overview">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <TextBlock Text="Device Overview" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,4"/>
                        <TextBlock x:Name="OverviewSubtitle" Foreground="{DynamicResource Brush.TextMuted}"
                                   Text="" Margin="0,0,0,12"/>

                        <TextBlock Text="Name" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="NameBox" Style="{StaticResource ModernTextBox}"/>

                        <TextBlock Text="Operating System" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="OsBox" Style="{StaticResource ModernTextBox}"/>

                        <TextBlock Text="CPU" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="CpuBox" Style="{StaticResource ModernTextBox}"/>

                        <TextBlock Text="GPU" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="GpuBox" Style="{StaticResource ModernTextBox}"/>

                        <TextBlock Text="RAM" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="RamBox" Style="{StaticResource ModernTextBox}"/>

                        <TextBlock Text="Notes / extra specs" Style="{StaticResource FieldLabel}"/>
                        <TextBox x:Name="SpecsBox" Style="{StaticResource ModernTextBox}"
                                 AcceptsReturn="True" TextWrapping="Wrap" MinHeight="50"/>

                        <TextBlock x:Name="SpecsHint" Foreground="{DynamicResource Brush.TextMuted}"
                                   FontSize="11" TextWrapping="Wrap" Margin="0,8,0,0" Text=""/>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                            <Button Content="Save changes" Style="{StaticResource ModernButton}" Click="SaveOverview_Click"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ============ LOGINS ============ -->
            <TabItem Header="Logins">
                <DockPanel Margin="16">
                    <Button DockPanel.Dock="Top" Content="+ Add login" Style="{StaticResource ModernButton}"
                            HorizontalAlignment="Left" Click="Button_Click"/>
                    <TextBlock DockPanel.Dock="Top" Margin="0,6,0,0" FontSize="11"
                               Foreground="{DynamicResource Brush.TextMuted}" TextWrapping="Wrap"
                               Text="Saved credentials for this device. Connect to open a session; the dot shows the live status."/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                        <StackPanel x:Name="LoginsStackPanel"/>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <!-- ============ INTERFACES ============ -->
            <TabItem Header="Interfaces">
                <DockPanel Margin="16">
                    <Button DockPanel.Dock="Top" x:Name="NewInterfaceButton" Content="+ New interface"
                            Style="{StaticResource ModernButton}"
                            HorizontalAlignment="Left" Click="Button_Click_7"/>
                    <TextBlock DockPanel.Dock="Top" x:Name="InterfacesHint" Margin="0,6,0,0" FontSize="11"
                               Foreground="{DynamicResource Brush.TextMuted}" TextWrapping="Wrap" Text=""/>
                    <!-- scrollable so a host with many NICs doesn't overflow -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                        <StackPanel x:Name="InterfacesStackPanel"/>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <!-- ============ SHELL ============ -->
            <TabItem Header="Shell">
                <TabControl x:Name="SshShellsTabControl" Background="{DynamicResource Brush.Surface}"
                            BorderThickness="0" SelectionChanged="SshShellsTabControl_SelectionChanged">
                    <TabItem Header="ssh-command">
                        <StackPanel Margin="12">
                            <TextBox x:Name="sshInputBox" Style="{StaticResource ModernTextBox}" Text="-_-"/>
                            <Button Content="Send" Style="{StaticResource ModernButton}"
                                    HorizontalAlignment="Left" Margin="0,6,0,6" Click="Button_Click_6"/>
                            <TextBlock x:Name="sshOutputBlock" TextWrapping="Wrap"
                                       FontFamily="Consolas"/>
                        </StackPanel>
                    </TabItem>
                    <TabItem Header="+" x:Name="addSshShellStream"/>
                </TabControl>
            </TabItem>

            <!-- ============ SNMP MIB BROWSER ============ -->
            <TabItem Header="MIB Browser">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- connection / community settings -->
                    <Border Grid.Row="0" Background="{DynamicResource Brush.SurfaceAlt}" CornerRadius="6" Padding="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,6,0">
                                <TextBlock Text="Read community" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="SnmpReadCommunity" Style="{StaticResource ModernTextBox}" Text="public"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,6,0">
                                <TextBlock Text="Write community" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="SnmpWriteCommunity" Style="{StaticResource ModernTextBox}" Text="private"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,6,0">
                                <TextBlock Text="Port" Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="SnmpPort" Style="{StaticResource ModernTextBox}" Width="60" Text="161"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="3">
                                <TextBlock Text="Version" Style="{StaticResource FieldLabel}"/>
                                <ComboBox x:Name="SnmpVersion" Width="70" SelectedIndex="0">
                                    <ComboBoxItem Content="v1"/>
                                    <ComboBoxItem Content="v2c"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" Margin="0,8,0,0">
                                <TextBlock Text="OID:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBox x:Name="SnmpOid" Style="{StaticResource ModernTextBox}" Width="220"
                                         Text="1.3.6.1.2.1.1"/>
                                <Button Content="Get" Style="{StaticResource ModernButton}" Click="SnmpGet_Click"/>
                                <Button Content="Walk" Style="{StaticResource ModernButton}" Click="SnmpWalk_Click"/>
                                <Button Content="Set" Style="{StaticResource SubtleButton}" Click="SnmpSet_Click"/>
                                <TextBox x:Name="SnmpSetValue" Style="{StaticResource ModernTextBox}" Width="120"
                                         VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- tree + results -->
                    <Grid Grid.Row="1" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="230"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{DynamicResource Brush.SurfaceAlt}" CornerRadius="6" Margin="0,0,8,0">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top" Text="Common OIDs" Margin="8,8,8,4"
                                           FontWeight="SemiBold"/>
                                <ListBox x:Name="MibTree" Background="Transparent" BorderThickness="0"
                                         Foreground="{DynamicResource Brush.Text}"
                                         SelectionChanged="MibTree_SelectionChanged"/>
                            </DockPanel>
                        </Border>

                        <Border Grid.Column="1" Background="{DynamicResource Brush.SurfaceAlt}" CornerRadius="6">
                            <DataGrid x:Name="SnmpResults" AutoGenerateColumns="False" IsReadOnly="True"
                                      Background="Transparent" Foreground="{DynamicResource Brush.Text}"
                                      RowBackground="Transparent" AlternatingRowBackground="#22FFFFFF"
                                      GridLinesVisibility="Horizontal" BorderThickness="0"
                                      HeadersVisibility="Column">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="OID"   Binding="{Binding Oid}"   Width="2*"/>
                                    <DataGridTextColumn Header="Value" Binding="{Binding Value}" Width="3*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ============ SFTP ============ -->
            <TabItem Header="SFTP">
                <StackPanel Margin="16">
                    <TextBlock Text="Local path" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="SftpLocalPath" Style="{StaticResource ModernTextBox}"/>
                    <TextBlock Text="Remote path" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="SftpRemotePath" Style="{StaticResource ModernTextBox}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Download" Style="{StaticResource ModernButton}" Click="Button_Click_1"/>
                        <Button Content="Upload" Style="{StaticResource ModernButton}" Click="Button_Click_2"/>
                        <Button Content="List remote dir" Style="{StaticResource SubtleButton}" Click="Button_Click_3"/>
                    </StackPanel>
                    <TextBlock x:Name="SftpDirList" Margin="0,8,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </TabItem>

            <!-- ============ SCP ============ -->
            <TabItem Header="SCP">
                <StackPanel Margin="16">
                    <TextBlock Text="Local path" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="ScpLocalPath" Style="{StaticResource ModernTextBox}"/>
                    <TextBlock Text="Remote path" Style="{StaticResource FieldLabel}"/>
                    <TextBox x:Name="ScpRemotePath" Style="{StaticResource ModernTextBox}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Download" Style="{StaticResource ModernButton}" Click="Button_Click_4"/>
                        <Button Content="Upload" Style="{StaticResource ModernButton}" Click="Button_Click_5"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- ============ ACCESS CONTROL ============ -->
            <TabItem Header="Access Control">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock x:Name="MyRoleLabel" Foreground="{DynamicResource Brush.TextMuted}" Text=""/>
                        <TextBlock x:Name="AccessHint" Foreground="{DynamicResource Brush.TextMuted}" FontSize="11"
                                   TextWrapping="Wrap" Margin="0,2,0,0" Text=""/>
                    </StackPanel>

                    <Border Grid.Row="1" x:Name="GrantPanel" Background="{DynamicResource Brush.SurfaceAlt}"
                            CornerRadius="6" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Set a user's access" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <StackPanel Orientation="Horizontal">
                                <!--KI start (Claude Opus 4.8, prompt 14/16): pick a real user from the DB. An explicit
                                    ItemTemplate with a Brush.Text TextBlock guarantees the names are visible in both the
                                    dropdown and the closed selection box (DisplayMemberPath text was invisible).-->
                                <ComboBox x:Name="PermUserCombo" Width="180" VerticalAlignment="Center">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding UserName}" Foreground="{DynamicResource Brush.Text}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                                <!--KI end-->
                                <ComboBox x:Name="RightLevel" Width="120" Margin="8,0,0,0" VerticalAlignment="Center"/>
                                <Button Content="Apply" Style="{StaticResource ModernButton}" Margin="8,0,0,0" Click="GrantPermission_Click"/>
                            </StackPanel>
                            <TextBlock Foreground="{DynamicResource Brush.TextMuted}" FontSize="11" Margin="0,6,0,0"
                                       TextWrapping="Wrap"
                                       Text="Admins may set Hidden/See/Edit on lower users. Only an Owner can set Admin/Owner or change another Admin/Owner."/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="2" Background="{DynamicResource Brush.SurfaceAlt}" CornerRadius="6" Margin="0,10,0,0">
                        <DataGrid x:Name="PermissionsGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                  Background="Transparent" Foreground="{DynamicResource Brush.Text}"
                                  RowBackground="Transparent" AlternatingRowBackground="#22FFFFFF"
                                  GridLinesVisibility="Horizontal" BorderThickness="0" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="User"  Binding="{Binding UserName}" Width="*"/>
                                <DataGridTextColumn Header="Right" Binding="{Binding Right}"    Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
    <!--KI end-->
</Window>
