<UserControl x:Class="RAT_WPF.NetworkObject_UI.InterfaceControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:RAT_WPF.NetworkObject_UI"
             mc:Ignorable="d"
             d:DesignHeight="44" MinWidth="260">
    <!--KI start (Claude Opus 4.8, prompt 2): host interface row with type icon, status, and (i) info button-->
    <Border Background="{DynamicResource Brush.SurfaceAlt}" CornerRadius="6" Margin="0,3" Padding="8,5">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0" x:Name="TypeIcon" Width="26" Height="26" Margin="0,0,10,0"/>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock x:Name="NameText" Foreground="{DynamicResource Brush.Text}" FontWeight="SemiBold"/>
                <TextBlock x:Name="SubText" Foreground="{DynamicResource Brush.TextMuted}" FontSize="11"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="6,0">
                <Ellipse x:Name="StatusDot" Width="9" Height="9" Margin="0,0,4,0"/>
                <TextBlock x:Name="StatusText" FontSize="11" Foreground="{DynamicResource Brush.TextMuted}"/>
            </StackPanel>

            <Button Grid.Column="3" Content="i" FontStyle="Italic" FontWeight="Bold"
                    Style="{StaticResource IconButton}" Click="Info_Click" ToolTip="Interface details"/>
        </Grid>
    </Border>
    <!--KI end-->
</UserControl>
