<UserControl x:Class="RAT_WPF.NetworkObject_UI.InterfaceControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:RAT_WPF.NetworkObject_UI"
             mc:Ignorable="d"
             d:DesignHeight="52" MinWidth="320">
    <!--KI start (Claude Opus 4.8, prompt 2/7): interface row — type icon, status pill, (i) details,
         plus edit/delete and an up/down toggle for software (non-host) interfaces -->
    <Border Background="{DynamicResource Brush.SurfaceAlt}" CornerRadius="8" Margin="0,4" Padding="10,7"
            BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0" x:Name="TypeIcon" Width="30" Height="30" Margin="0,0,12,0"
                   VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock x:Name="NameText" Foreground="{DynamicResource Brush.Text}"
                           FontWeight="SemiBold" FontSize="13"/>
                <TextBlock x:Name="SubText" Foreground="{DynamicResource Brush.TextMuted}" FontSize="11"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <!-- status pill -->
            <Border Grid.Column="2" x:Name="StatusPill" CornerRadius="10" Padding="8,2" Margin="6,0"
                    VerticalAlignment="Center" Background="{DynamicResource Brush.SurfaceAlt}">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8" Margin="0,0,5,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="StatusText" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"
                               Foreground="{DynamicResource Brush.Text}"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                <!-- software-only actions -->
                <Button x:Name="ToggleButton" Content="Toggle" Style="{StaticResource SubtleButton}"
                        Click="Toggle_Click" ToolTip="Bring the interface up / down" Visibility="Collapsed"/>
                <Button x:Name="EditButton" Content="Edit" Style="{StaticResource AccentOutlineButton}"
                        Click="Edit_Click" Visibility="Collapsed"/>
                <Button x:Name="DeleteButton" Content="Delete" Style="{StaticResource DangerButton}"
                        Click="Delete_Click" Visibility="Collapsed"/>
                <!-- always available -->
                <Button x:Name="InfoButton" Content="i" FontStyle="Italic" FontWeight="Bold"
                        Style="{StaticResource IconButton}" Click="Info_Click" ToolTip="Interface details"/>
            </StackPanel>
        </Grid>
    </Border>
    <!--KI end-->
</UserControl>
