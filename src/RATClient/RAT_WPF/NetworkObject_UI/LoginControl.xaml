<UserControl x:Class="RAT_WPF.NetworkObject_UI.LoginControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:RAT_WPF.NetworkObject_UI"
             mc:Ignorable="d"
             d:DesignHeight="52" MinWidth="320">
    <!--KI start (Claude Opus 4.8, prompt 1/2/7): login row — protocol icon, status pill, actions (colored Edit)-->
    <Border Background="{DynamicResource Brush.SurfaceAlt}" CornerRadius="8" Margin="0,4" Padding="10,7"
            BorderBrush="{DynamicResource Brush.Border}" BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" x:Name="ProtocolText" FontWeight="SemiBold" FontSize="13" MinWidth="48"
                       VerticalAlignment="Center" Foreground="{DynamicResource Brush.Text}"/>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                <TextBlock x:Name="UserText" Foreground="{DynamicResource Brush.Text}" FontSize="12"/>
                <TextBlock x:Name="PortText" Foreground="{DynamicResource Brush.TextMuted}" FontSize="11"/>
            </StackPanel>

            <!-- status pill -->
            <Border Grid.Column="2" CornerRadius="10" Padding="8,2" Margin="6,0" VerticalAlignment="Center"
                    Background="{DynamicResource Brush.SurfaceAlt}">
                <StackPanel Orientation="Horizontal">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8" Margin="0,0,5,0"
                             VerticalAlignment="Center" Fill="{DynamicResource Brush.Danger}"/>
                    <TextBlock x:Name="StatusText" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"
                               Foreground="{DynamicResource Brush.Text}" Text="not connected"/>
                </StackPanel>
            </Border>

            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="ConnectButton" Content="Connect" Style="{StaticResource ModernButton}" Click="Button_Click"/>
                <Button Content="Edit" Style="{StaticResource AccentOutlineButton}" Click="Button_Click_1"/>
                <Button Content="Delete" Style="{StaticResource DangerButton}" Click="Delete_Click"/>
            </StackPanel>
        </Grid>
    </Border>
    <!--KI end-->
</UserControl>
