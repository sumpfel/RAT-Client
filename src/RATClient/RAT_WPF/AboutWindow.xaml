<Window x:Class="RAT_WPF.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RAT_WPF"
        mc:Ignorable="d"
        Title="About RAT" Width="480" SizeToContent="Height" MaxHeight="640"
        Icon="{StaticResource AppLogo}"
        Background="{DynamicResource Brush.Background}"
        TextElement.Foreground="{DynamicResource Brush.Text}"
        FontFamily="Segoe UI"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <!--KI start (Claude Opus 4.8, prompt 17): About window — fancy credits + rat mascot graphic -->
    <Border Margin="16" Background="{DynamicResource Brush.Surface}" CornerRadius="10" Padding="22">
        <DockPanel>
            <StackPanel DockPanel.Dock="Bottom" HorizontalAlignment="Right" Orientation="Horizontal" Margin="0,18,0,0">
                <Button Content="Close" Style="{StaticResource ModernButton}" MinWidth="90"
                        Click="Close_Click" IsDefault="True"/>
            </StackPanel>

            <!-- hero rat -->
            <Border DockPanel.Dock="Top" HorizontalAlignment="Center" Width="120" Height="120" Margin="0,0,0,6">
                <Image Source="{StaticResource Icon.AboutRat}" Stretch="Uniform"/>
            </Border>

            <StackPanel>
                <TextBlock Text="RAT" HorizontalAlignment="Center" FontSize="30" FontWeight="Bold"
                           Foreground="{DynamicResource Brush.Heading}"/>
                <TextBlock HorizontalAlignment="Center" FontSize="13" Margin="0,2,0,0"
                           Foreground="{DynamicResource Brush.TextMuted}"
                           Text="Remote Administration &amp; Topology — real networks, central control."/>

                <Border Background="{DynamicResource Brush.SurfaceAlt}" CornerRadius="8" Padding="16" Margin="0,18,0,0">
                    <StackPanel>
                        <TextBlock TextWrapping="Wrap" TextAlignment="Center" FontSize="14" LineHeight="22"
                                   Foreground="{DynamicResource Brush.Text}">
                            <Run Text="Lovingly crafted by "/>
                            <Run Text="Tobias" FontWeight="Bold" Foreground="{DynamicResource Brush.Accent}"/>
                            <Run Text=" and "/>
                            <Run Text="Claude" FontWeight="Bold" Foreground="{DynamicResource Brush.Accent}"/>
                            <Run Text=", with the steadfast assistance of his trusty helper "/>
                            <Run Text="Christof" FontWeight="Bold" Foreground="{DynamicResource Brush.Accent}"/>
                            <Run Text="."/>
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" TextAlignment="Center" FontSize="12" Margin="0,12,0,0"
                                   Foreground="{DynamicResource Brush.TextMuted}"
                                   Text="Forged through countless prompts, late-night merges, and an unreasonable number of brown colour swatches — this rat scurries through your network so you don't have to."/>
                    </StackPanel>
                </Border>

                <TextBlock HorizontalAlignment="Center" Margin="0,14,0,0" FontSize="11"
                           Foreground="{DynamicResource Brush.TextMuted}"
                           Text="🐀  Made with fur, wire, and a little bit of mischief."/>
            </StackPanel>
        </DockPanel>
    </Border>
    <!--KI end-->
</Window>
