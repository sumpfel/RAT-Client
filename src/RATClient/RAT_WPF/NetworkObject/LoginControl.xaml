<UserControl x:Class="RAT_WPF.NetworkObject.LoginControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RAT_WPF.NetworkObject"
             mc:Ignorable="d" 
             d:DesignHeight="30" MinWidth="200">
    <Grid Background="LightGray">
        <StackPanel Orientation="Horizontal" Margin="2">
            <Label Content="port: "></Label>
            <Label Content="user: "></Label>
            <Label Content="potocoll: "></Label>
            <Button Content="connect" Margin="2"></Button>
            <Button Content="edit" Margin="2"></Button>
            <Button Content="delete" Margin="2"></Button>
        </StackPanel>
    </Grid>
</UserControl>
