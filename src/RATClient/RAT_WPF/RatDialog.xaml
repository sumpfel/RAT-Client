<Window x:Class="RAT_WPF.RatDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RAT_WPF"
        mc:Ignorable="d"
        Title="RAT" Width="440" MinWidth="360" SizeToContent="Height" MaxHeight="560"
        Icon="{StaticResource AppLogo}"
        Background="{DynamicResource Brush.Background}"
        TextElement.Foreground="{DynamicResource Brush.Text}"
        FontFamily="Segoe UI"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <!--KI start (Claude Opus 4.8, prompt 17): themed message dialog with a rat vector graphic -->
    <Border Margin="16" Background="{DynamicResource Brush.Surface}" CornerRadius="8" Padding="18">
        <DockPanel>
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button x:Name="OkButton" Content="OK" Style="{StaticResource ModernButton}" MinWidth="80"
                        Click="Ok_Click" IsDefault="True"/>
            </StackPanel>

            <Image x:Name="RatImage" DockPanel.Dock="Left" Width="84" Height="84" Margin="0,0,16,0"
                   VerticalAlignment="Top" Stretch="Uniform"/>

            <StackPanel>
                <TextBlock x:Name="HeadingText" FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource Brush.Heading}" TextWrapping="Wrap"/>
                <TextBlock x:Name="MessageText" Margin="0,8,0,0" TextWrapping="Wrap"
                           Foreground="{DynamicResource Brush.Text}"/>
            </StackPanel>
        </DockPanel>
    </Border>
    <!--KI end-->
</Window>
