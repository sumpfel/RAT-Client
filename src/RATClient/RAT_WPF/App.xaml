<Application x:Class="RAT_WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:RAT_WPF">
    <Application.Resources>
        <Style TargetType="TextBlock" x:Key="Header">
            <Setter Property="FontSize" Value="24"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="Header2">
            <Setter Property="FontSize" Value="20"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="Header3">
            <Setter Property="FontSize" Value="16"/>
        </Style>
        <Style TargetType="RadioButton" x:Key="RadioButtonTool">
            <!--TODO: Style Tools in Mainwindow-->
        </Style>
    </Application.Resources>
</Application>
