<Window x:Class="RAT_WPF.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vms="clr-namespace:RAT_WPF.ViewModels"
        mc:Ignorable="d"
        Title="Settings" Width="420" MinWidth="360"
        SizeToContent="Height" MaxHeight="600"
        Icon="{StaticResource AppLogo}"
        Background="{DynamicResource Brush.Background}"
        FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">
    <!--KI start (Claude Opus 4.8, prompt 2/3): MVVM settings window; SizeToContent + docked button bar so Apply/Close always fit-->
    <Window.DataContext>
        <vms:SettingsViewModel/>
    </Window.DataContext>
    <Border Style="{StaticResource Card}" Margin="16">
        <DockPanel>
            <!-- button bar is docked to the bottom so it never scrolls out of reach -->
            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="Apply" Style="{StaticResource ModernButton}"
                        Command="{Binding ApplyThemeCommand}"/>
                <Button Content="Close" Style="{StaticResource SubtleButton}" Click="Close_Click"/>
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Image Source="{StaticResource AppLogo}" Width="40" Height="40" Margin="0,0,10,0"/>
                        <TextBlock Text="Settings" Style="{StaticResource Header}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Text="Appearance" Style="{StaticResource Header3}" Margin="0,4,0,2"/>
                    <TextBlock Text="Theme" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding Themes}"
                              SelectedItem="{Binding SelectedTheme, Mode=TwoWay}"
                              Width="160" HorizontalAlignment="Left"/>

                    <TextBlock Margin="0,16,0,0" TextWrapping="Wrap" FontSize="12"
                               Foreground="{DynamicResource Brush.TextMuted}"
                               Text="Light uses the paper + brown 'rats' palette; Dark uses the same fur tones on a dark base. The change applies instantly across all windows."/>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
    <!--KI end-->
</Window>
